# Server
PORT=8081

# Database
DB_URL=jdbc:mysql://localhost:3306/DHV
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Logging
LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO

# Thymeleaf
THYMELEAF_CACHE=true

# Upload directory (default: ./uploads)
UPLOAD_DIR=./uploads

# GHCR (for docker-compose on server)
GHCR_REPO=your-github-username/your-repo

# Default admin (optional, used on fresh DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
